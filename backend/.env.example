NODE_ENV=development
PORT=3333

# Chave da API de IA.
# O Ollama ignora a chave, mas IaServico exige um valor não-vazio.
# Para provedores reais (OpenAI, OpenRouter, etc.) coloque a chave verdadeira.
AI_API_KEY=ollama

# Modelo usado pela IA. Para Ollama, precisa estar baixado (ollama pull <modelo>).
AI_MODEL=qwen2.5:0.5b

# URL da API compatível com Chat Completions.
# Backend rodando DENTRO do docker-compose -> use o NOME DO SERVIÇO do Ollama:
AI_API_URL=http://ollama:11434/v1/chat/completions
# Backend rodando NA MÁQUINA (npm run dev fora do Docker) -> use localhost:
# AI_API_URL=http://localhost:11434/v1/chat/completions
